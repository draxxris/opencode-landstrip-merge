{
    "filesystem": {
        "allowWrite": [
            ".",
            "/tmp/opencode-scratch",
            "/tmp/landstrip",
            "~/opencode-trace",
            "~/.cache",
            "~/.local/share",
            "~/.local/state",
            "~/.npm/_logs",
            "~/.npm/_cacache",
            "~/.npm/_update-notifier-last-checked",
            "/dev/null",
            "~/.herdr/worktrees"
        ],
        "denyRead": [
            "~/.ssh"
        ],
        "allowRead": [
            "/etc/passwd",
            "/usr",
            "/var",
            "/proc",
            "~/.config/opencode",
            "~/.local",
            "~/.npm",
            "~/.ssh/config"
        ]
    },
    "network": {
        "allowNetwork": true
    }
}
